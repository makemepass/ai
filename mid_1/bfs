def bfs(graph, node, target):
    queue = [node]
    visited = [node]
    path_to_target = []
    full_traversal = []
    found = False
    while queue:
        current = queue.pop(0)
        full_traversal.append(current)
        if not found:
            path_to_target.append(current)
            if current == target:
                found = True
        for i in graph.get(current, []):
            if i not in visited:
                visited.append(i)
                queue.append(i)
    return path_to_target, full_traversal
graph = {
    'A': ['B', 'C'],
    'B': ['A', 'D', 'E'],
    'C': ['A', 'F', 'G'],
    'D': ['B'],
    'E': ['B'],
    'F': ['C'],
    'G': ['C']
}
user = input("enter target variables in sequence: ")
targets = list(user)
print(targets)
path, full = bfs(graph, 'A', targets[1])
print(*(path))
print(*(full))
